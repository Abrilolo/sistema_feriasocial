# ============================================
# CONFIGURACIÓN DE BASE DE DATOS
# ============================================
# !IMPORTANTE: usa el host db.<ref>.supabase.co (no el de api)
# *Tu user/pass vienen del panel de Supabase (Database settings)
# Ejemplo de formato para Supabase:
# DATABASE_URL=postgresql+psycopg://postgres:[PASSWORD]@db.[PROJECT_REF].supabase.co:5432/postgres?sslmode=require

DATABASE_URL=postgresql+psycopg://postgres:TU_PASSWORD_AQUI@db.TU_PROYECTO.supabase.co:5432/postgres?sslmode=require

# Para desarrollo local (opcional)
USE_LOCAL_DB=0
LOCAL_DATABASE_URL=postgresql+psycopg://postgres:postgres@127.0.0.1:5432/feria

# ============================================
# CONFIGURACIÓN JWT - SEGURIDAD CRÍTICA
# ============================================
# JWT_SECRET debe ser una cadena aleatoria de al menos 32 caracteres
# Genera uno seguro con: openssl rand -hex 32
# ¡NUNA uses valores por defecto o cortos!

JWT_SECRET=GENERA_UN_SECRET_LARGO_Y_ALEATORIO_DE_AL_MENOS_32_CARACTERES_AQUI
JWT_ALG=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# ============================================
# CONFIGURACIÓN GOOGLE OAUTH - LOGIN ESTUDIANTES
# ============================================
# Obtén estas credenciales en: https://console.cloud.google.com/
# 1. Crea un proyecto
# 2. Configura OAuth Consent Screen
# 3. Crea OAuth 2.0 Client IDs (Tipo: Web Application)
# 4. Agrega redirect URIs:
#    - http://localhost:8000/auth/google/callback (desarrollo)
#    - https://tu-dominio.com/auth/google/callback (producción)

GOOGLE_CLIENT_ID=XXXXX.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=XXXXX

# Dominio permitido para estudiantes (ej: tec.mx)
STUDENT_EMAIL_DOMAIN=tec.mx

# ============================================
# CONFIGURACIÓN DE ENTORNO
# ============================================
# development | production
ENVIRONMENT=development

# URL del frontend para CORS (requerido en producción)
FRONTEND_URL=https://tu-dominio.com

# Orígenes adicionales permitidos (separados por coma)
# ADDITIONAL_ALLOWED_ORIGINS=https://otro-dominio.com,https://app.ejemplo.com
